{
  "name": "azeroth-editor",
  "version": "0.1.0",
  "description": "AzerothCore World Editor",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "test:textures": "node tests/semantic-textures.test.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^8.18.0",
    "@wowserhq/stormjs": "^0.4.1",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^9.6.0",
    "lucide-react": "^0.383.0",
    "mysql2": "^3.9.0",
    "node-pty": "^1.1.0",
    "node-soap": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.azeroth.editor",
    "productName": "Azeroth Editor",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
